---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'long lost forgotten',
  description = 'a personal log. irregular transmission.',
} = Astro.props;

const currentPath = Astro.url.pathname;

const nav = [
  { label: 'home',    href: '/'        },
  { label: 'archive', href: '/archive' },
  { label: 'about',   href: '/about'   },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title === 'long lost forgotten' ? title : `${title} · long lost forgotten`}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <div class="site-wrap">
      <header class="site-header">
        <a href="/" class="site-title">long lost forgotten</a>
        <nav class="site-nav" aria-label="Main navigation">
          {nav.map(({ label, href }) => {
            const isActive = href === '/'
              ? currentPath === '/'
              : currentPath.startsWith(href);
            return (
              <a href={href} class:list={['nav-link', { active: isActive }]} aria-current={isActive ? 'page' : undefined}>
                {label}
              </a>
            );
          })}
        </nav>
      </header>

      <main>
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  .site-wrap {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .site-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--surface0);
    margin-bottom: 2.5rem;
  }

  .site-title {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--mauve);
    letter-spacing: 0.04em;
    text-decoration: none;
  }

  .site-title:hover {
    color: var(--mauve);
  }

  .site-nav {
    display: flex;
    gap: 1.5rem;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--subtext0);
    text-decoration: none;
    letter-spacing: 0.03em;
  }

  .nav-link:hover {
    color: var(--text);
  }

  .nav-link.active {
    color: var(--lavender);
  }
</style>
