---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  image?: string;
}

const {
  title = 'long lost forgotten',
  description = 'a personal log. irregular transmission.',
  image,
} = Astro.props;

const currentPath = Astro.url.pathname;
const canonicalUrl = Astro.url.href;
const ogImage = new URL(image ?? '/images/social_basecard.png', Astro.url.origin).href;
const ogTitle = title === 'long lost forgotten' ? title : `${title} · long lost forgotten`;

const nav = [
  { label: 'home',    href: '/'        },
  { label: 'archive', href: '/archive' },
  { label: 'about',   href: '/about'   },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="fediverse:creator" content="@longlostforgotten@mastodon.social">
    <link rel="canonical" href={canonicalUrl} />

    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content={image ? '1200' : '1199'} />
    <meta property="og:image:height" content={image ? '630' : '622'} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <title>{ogTitle}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.7.2/css/all.min.css" />
  </head>
  <body>
    <div class="site-wrap">
      <header class="site-header">
          <a rel="me" href="/" class="site-title">longlostforgotten</a>
        <nav class="site-nav" aria-label="Main navigation">
          {nav.map(({ label, href }) => {
            const isActive = href === '/'
              ? currentPath === '/'
              : currentPath.startsWith(href);
            return (
              <a href={href} class:list={['nav-link', { active: isActive }]} aria-current={isActive ? 'page' : undefined}>
                {label}
              </a>
            );
          })}
        </nav>
      </header>

      <main>
        <slot />
      </main>
    </div>
  </body>
</html>

<style>
  .site-wrap {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 2rem 1.5rem 4rem;
  }

  .site-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--surface0);
    margin-bottom: 2.5rem;
  }

  .site-title {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    color: var(--mauve);
    letter-spacing: 0.04em;
    text-decoration: none;
  }

  .site-title:hover {
    color: var(--mauve);
  }

  .site-nav {
    display: flex;
    gap: 1.5rem;
  }

  .nav-link {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--subtext0);
    text-decoration: none;
    letter-spacing: 0.03em;
  }

  .nav-link:hover {
    color: var(--text);
  }

  .nav-link.active {
    color: var(--lavender);
  }
</style>
