---
import Base from '../../layouts/Base.astro';
import { getCollection, getEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', p => !p.data.draft);
  return posts.map(post => ({ params: { slug: post.id } }));
}

const { slug } = Astro.params;
const post = await getEntry('posts', slug!);

if (!post) return Astro.redirect('/404');

const { Content } = await render(post);

const formatted = new Date(post.data.date).toLocaleDateString('en-US', {
  month: 'long',
  day: 'numeric',
  year: 'numeric',
});
---

<Base title={post.data.title} description={post.data.excerpt} image={post.data.image}>
  <article>
    <header class="post-header">
      <p class="post-meta">
        <time datetime={post.data.date}>{formatted}</time>
        {post.data.tag && (
          <>
            <span class="meta-sep">·</span>
            {(Array.isArray(post.data.tag) ? post.data.tag : [post.data.tag]).map(t => (
              <span class="post-tag">{t}</span>
            ))}
          </>
        )}
      </p>
      <h1 class="post-title">{post.data.title}</h1>
      <!-- {post.data.excerpt && <p class="post-excerpt">{post.data.excerpt}</p>} -->
    </header>

    <div class="post-body">
      <Content />
    </div>

    {(post.data.currentMood || post.data.currentMusic) && (
      <div class="post-vibes">
        {post.data.currentMood && (
          <span class="vibe-item">
            <span class="vibe-label">mood</span>
            <span class="vibe-value">{post.data.currentMood}</span>
          </span>
        )}
        {post.data.currentMusic && (
          <span class="vibe-item">
            <span class="vibe-label">listening to</span>
            <span class="vibe-value">{post.data.currentMusic}</span>
          </span>
        )}
      </div>
    )}

    {(post.data.blueskyUrl || post.data.mastodonUrl) && (
      <aside class="discussion">
        <p class="discussion-label">join the discussion</p>
        <div class="discussion-links">
          {post.data.blueskyUrl && (
            <a href={post.data.blueskyUrl} target="_blank" rel="noopener noreferrer" class="discussion-link">
              <i class="fa-brands fa-bluesky"></i>
              <span>bluesky</span>
            </a>
          )}
          {post.data.mastodonUrl && (
            <a href={post.data.mastodonUrl} target="_blank" rel="noopener noreferrer" class="discussion-link">
              <i class="fa-brands fa-mastodon"></i>
              <span>mastodon</span>
            </a>
          )}
        </div>
      </aside>
    )}

    <footer class="post-footer">
      <a href="/archive" class="back-link">← archive</a>
    </footer>
  </article>
</Base>

<style>
  article {
    max-width: 600px;
  }

  .post-header {
    margin-bottom: 2.5rem;
    padding-bottom: 1.5rem;
    border-bottom: 1px solid var(--surface0);
  }

  .post-meta {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--overlay0);
    letter-spacing: 0.02em;
    margin-bottom: 0.75rem;
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 6px;
  }

  .meta-sep {
    color: var(--surface1);
  }

  .post-tag {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--mauve);
    background: rgba(203, 166, 247, 0.08);
    border: 1px solid rgba(203, 166, 247, 0.2);
    padding: 1px 6px;
    border-radius: 3px;
  }

  .post-title {
    font-size: 22px;
    font-weight: 500;
    color: var(--text);
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }

  .post-excerpt {
    font-size: 14px;
    color: var(--subtext0);
    line-height: 1.6;
  }

  /* ─── Prose styles ─── */
  .post-body {
    font-size: 15px;
    color: var(--subtext1);
    line-height: 1.8;
  }

  .post-body :global(p) {
    margin-bottom: 1.25rem;
  }

  .post-body :global(h2) {
    font-size: 17px;
    font-weight: 500;
    color: var(--text);
    margin: 2rem 0 0.75rem;
  }

  .post-body :global(h3) {
    font-size: 15px;
    font-weight: 500;
    color: var(--text);
    margin: 1.5rem 0 0.5rem;
  }

  .post-body :global(a) {
    color: var(--lavender);
    text-decoration: underline;
    text-decoration-color: rgba(180, 190, 254, 0.3);
    text-underline-offset: 3px;
  }

  .post-body :global(a:hover) {
    color: var(--mauve);
    text-decoration-color: var(--mauve);
  }

  .post-body :global(code) {
    font-family: var(--font-mono);
    font-size: 13px;
    color: var(--peach);
    background: var(--surface0);
    padding: 1px 5px;
    border-radius: 3px;
  }

  .post-body :global(pre) {
    background: var(--mantle);
    border: 1px solid var(--surface0);
    border-radius: 4px;
    padding: 1rem 1.25rem;
    overflow-x: auto;
    margin-bottom: 1.25rem;
  }

  .post-body :global(pre code) {
    background: none;
    padding: 0;
    font-size: 13px;
    color: var(--text);
  }

  .post-body :global(blockquote) {
    border-left: 2px solid var(--surface1);
    padding-left: 1rem;
    color: var(--subtext0);
    font-style: italic;
    margin: 1.25rem 0;
  }

  .post-body :global(ul),
  .post-body :global(ol) {
    padding-left: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .post-body :global(li) {
    margin-bottom: 0.4rem;
  }

  .post-body :global(hr) {
    border: none;
    border-top: 1px solid var(--surface0);
    margin: 2rem 0;
  }

  .post-vibes {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--surface0);
    display: flex;
    flex-wrap: wrap;
    gap: 1.25rem;
  }

  .vibe-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .vibe-label {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--overlay0);
    letter-spacing: 0.05em;
    text-transform: lowercase;
  }

  .vibe-value {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--subtext1);
  }

  .discussion {
    margin-top: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--surface0);
  }

  .post-vibes + .discussion {
    margin-top: 1.25rem;
    padding-top: 1.25rem;
    border-top: none;
  }

  .discussion-label {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--overlay0);
    letter-spacing: 0.05em;
    text-transform: lowercase;
    margin-bottom: 0.75rem;
  }

  .discussion-links {
    display: flex;
    gap: 1.25rem;
  }

  .discussion-link {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--subtext0);
    text-decoration: none;
  }

  .discussion-link i {
    font-size: 14px;
  }

  .discussion-link:hover {
    color: var(--lavender);
  }

  .post-footer {
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--surface0);
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--overlay1);
    text-decoration: none;
  }

  .back-link:hover {
    color: var(--subtext0);
  }
</style>
