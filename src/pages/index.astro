---
import Base from '../layouts/Base.astro';
import PostCard from '../components/PostCard.astro';
import SectionLabel from '../components/SectionLabel.astro';
import HomeEditor from '../components/HomeEditor';
import { getCollection } from 'astro:content';
import { client } from '../../tina/__generated__/client';
import homeJson from '../content/home.json';

const allPosts = await getCollection('posts');
const posts = allPosts
  .filter(p => !p.data.draft)
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 5);

let homeResult: Awaited<ReturnType<typeof client.queries.home>>;
try {
  homeResult = await client.queries.home({ relativePath: 'home.json' });
} catch {
  homeResult = {
    data: { home: homeJson as any },
    query: '',
    variables: { relativePath: 'home.json' },
  };
}
---

<Base>
  <HomeEditor {...homeResult} client:tina />

  <SectionLabel label="recent posts" />

  <ul class="post-list" aria-label="Recent posts">
    {posts.map(post => (
      <PostCard
        title={post.data.title}
        slug={post.id}
        date={post.data.date}
        excerpt={post.data.excerpt}
        tag={post.data.tag}
      />
    ))}
  </ul>

  <a href="/archive" class="archive-link">view full archive →</a>
</Base>

<style is:global>
  .intro {
    margin-bottom: 3rem;
  }

  .tagline {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--overlay1);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.75rem;
  }

  .headline {
    font-family: var(--font-sans);
    font-size: 22px;
    font-weight: 500;
    color: var(--text);
    line-height: 1.3;
    margin-bottom: 0.75rem;
  }

  .desc {
    font-size: 14px;
    color: var(--subtext0);
    max-width: 480px;
  }

  .post-list {
    list-style: none;
    margin-bottom: 2rem;
  }

  .post-list > :global(li:first-child) {
    border-top: 1px solid var(--surface0);
  }

  .archive-link {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--overlay1);
    text-decoration: none;
  }

  .archive-link:hover {
    color: var(--subtext0);
  }
</style>
