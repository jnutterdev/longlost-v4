---
import Base from '../layouts/Base.astro';
import { client } from '../../tina/__generated__/client';
import AboutEditor from '../components/AboutEditor';
import aboutJson from '../content/about.json';

let result: Awaited<ReturnType<typeof client.queries.about>>;
try {
  result = await client.queries.about({ relativePath: 'about.json' });
} catch {
  result = {
    data: { about: aboutJson as any },
    query: '',
    variables: { relativePath: 'about.json' },
  };
}
---

<Base title="about">
  <AboutEditor {...result} client:load />
</Base>

<style is:global>
  .about-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--surface0);
    border: 1px solid var(--surface1);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 18px;
    color: var(--mauve);
    object-fit: cover;
  }

  .about-name {
    font-weight: 500;
    font-size: 17px;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .about-handle {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--mauve);
    margin-bottom: 1.5rem;
  }

  .about-body {
    font-size: 14px;
    color: var(--subtext0);
    line-height: 1.75;
    max-width: 500px;
  }

  .about-body p + p {
    margin-top: 1rem;
  }

  .about-links {
    display: flex;
    gap: 1.25rem;
    margin-top: 1.75rem;
  }

  .about-link {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--lavender);
    text-decoration: none;
  }

  .about-link:hover {
    color: var(--mauve);
  }
</style>
