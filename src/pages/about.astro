---
import Base from '../layouts/Base.astro';
import about from '../content/about.json';

const bioParagraphs = about.bio
  ? about.bio.split(/\n\n+/).filter(p => p.trim())
  : [];
---

<Base title="about">
  {about.avatar
    ? <img class="about-avatar" src={about.avatar} alt={about.avatarAlt ?? about.name} />
    : <div class="about-avatar" aria-hidden="true">j</div>
  }
  <p class="about-name">{about.name}</p>
  <p class="about-handle">{about.handle} · {about.location}</p>
  <div class="about-body">
    {bioParagraphs.map(p => <p>{p}</p>)}
  </div>
  <nav class="about-links" aria-label="External links">
    {about.links?.map(link => (
      <a href={link.url ?? '#'} class="about-link">{link.label}</a>
    ))}
  </nav>
</Base>

<style is:global>
  .about-avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--surface0);
    border: 1px solid var(--surface1);
    margin-bottom: 1.25rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-mono);
    font-size: 18px;
    color: var(--mauve);
    object-fit: cover;
  }

  .about-name {
    font-weight: 500;
    font-size: 17px;
    color: var(--text);
    margin-bottom: 0.25rem;
  }

  .about-handle {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--mauve);
    margin-bottom: 1.5rem;
  }

  .about-body {
    font-size: 14px;
    color: var(--subtext0);
    line-height: 1.75;
    max-width: 500px;
  }

  .about-body p + p {
    margin-top: 1rem;
  }

  .about-links {
    display: flex;
    gap: 1.25rem;
    margin-top: 1.75rem;
  }

  .about-link {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--lavender);
    text-decoration: none;
  }

  .about-link:hover {
    color: var(--mauve);
  }
</style>
